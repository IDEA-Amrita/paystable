#paystable configuration
#copy this file to .env and fill in your values

#required
DATABASE_URL=postgres://user:password@localhost:5432/paystable?sslmode=disable
GATEWAY=payu
WEBHOOK_SECRET=your_payu_salt_here
GATEWAY_API_KEY=your_payu_merchant_key_here
PAYU_STATUS_URL=https://info.payu.in/merchant/postservice.php?form=2
MERCHANT_CALLBACK_SECRET=secret_for_signing_outbound_callbacks
ADMIN_API_KEY=secret_for_admin_endpoints

#optional (defaults shown)
#PORT=8080
#STABILIZATION_N=3
#MAX_BACKOFF_S=160
#HOLD_MAX_TTL_S=900
#LOG_LEVEL=info
#DELIVERY_TIMEOUT_S=10
#DELIVERY_WORKER_CONCURRENCY=20
#DELIVERY_ALLOW_INSECURE_CALLBACK=false
#DASHBOARD_ENABLED=false
